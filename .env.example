# -------------------------------------------------------------------
# Colombia Environmental Data Pipeline — environment variables
#
# Copy this file to `.env` and fill in the real values. `.env` is
# gitignored; `.env.example` is not.
# -------------------------------------------------------------------

# --- Google Cloud -------------------------------------------------
# Project ID that terraform will create resources in.
GCP_PROJECT=your-gcp-project-id

# Path to a service-account JSON key that has:
#   roles/storage.objectAdmin  on the data lake bucket
#   roles/bigquery.dataEditor  on both datasets
#   roles/bigquery.jobUser     at the project level
# Terraform can create this account for you (set create_service_account = true in
# terraform.tfvars), or you can reuse an existing one.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/your-sa-key.json

# --- GCS data lake -----------------------------------------------
# Must match the `bucket_name` you set in terraform.tfvars.
GCS_BUCKET=colombia-env-pipeline-your-unique-suffix

# --- BigQuery ----------------------------------------------------
BQ_REGION=us-central1
RAW_DATASET=colombia_env_raw
WAREHOUSE_DATASET=colombia_env_warehouse

# --- OpenAQ v3 ---------------------------------------------------
# Free registration: https://explore.openaq.org/register
OPENAQ_API_KEY=your-openaq-api-key-here

# --- Kafka (local docker-compose) --------------------------------
KAFKA_BOOTSTRAP=kafka:29092
KAFKA_TOPIC=weather.sensor.readings
EMIT_INTERVAL_SEC=2
BATCH_SIZE=100
BATCH_TIMEOUT_SEC=30
